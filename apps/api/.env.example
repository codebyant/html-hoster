# ── RAILWAY DEPLOYMENT ────────────────────────────────────────────────────────
# Set these in the Railway dashboard under Variables.
# Railway filesystem is ephemeral — use STORAGE_DRIVER=s3 for persistent data.
# PUBLIC_BASE_URL → use your Railway domain, e.g. https://html-hoster.up.railway.app
# ──────────────────────────────────────────────────────────────────────────────

# Required
API_KEY=change-me-to-a-secure-random-string
PUBLIC_BASE_URL=http://localhost:3000

# App mode: development | demo | production (default)
# development → swagger enabled, all features
# demo        → swagger enabled (read-only), write endpoints blocked, no-op storage
# production  → swagger disabled, all features
APP_ENV=production

# Storage: "local" (default) or "s3"
STORAGE_DRIVER=local

# Local storage (only used when STORAGE_DRIVER=local)
LOCAL_STORAGE_DIR=./data

# S3 (only used when STORAGE_DRIVER=s3)
S3_BUCKET=                 # required
S3_ACCESS_KEY_ID=          # required
S3_SECRET_ACCESS_KEY=      # required
S3_REGION=us-east-1        # optional (default us-east-1)
S3_ENDPOINT=               # optional — set for MinIO / R2 / non-AWS

# Landing page
# ROOT_REDIRECT=https://yoursite.com   — redirects / to this URL (takes priority over DISABLE_LANDING)
# DISABLE_LANDING=true                 — returns 404 for /
DISABLE_LANDING=false

# Limits
MAX_HTML_SIZE_MB=5

# Server
PORT=3000
